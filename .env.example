# ============================================================
# OMNICHANNEL SYSTEM - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Application ---
NODE_ENV=production
APP_NAME="OmniSuite"
APP_URL=http://localhost
APP_PORT=3001

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost
NEXT_PUBLIC_APP_NAME="OmniSuite"
INTERNAL_API_URL=http://backend:3001

# --- Database ---
POSTGRES_DB=omnichannel
POSTGRES_USER=omni
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://omni:change_me_strong_password@postgres:5432/omnichannel

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379

# --- JWT ---
JWT_SECRET=change_me_very_long_jwt_secret_min_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# --- WhatsApp / Meta ---
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=change_me_webhook_verify_token
META_GRAPH_API_VERSION=v19.0
META_GRAPH_API_URL=https://graph.facebook.com

# --- Google Drive ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/integrations/google/callback

# --- Asterisk AMI ---
ASTERISK_HOST=asterisk
ASTERISK_AMI_ENABLED=true
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=omni_ami
ASTERISK_AMI_SECRET=change_me_ami_secret
ASTERISK_ARI_URL=http://asterisk:8088
ASTERISK_ARI_USER=omni_ari
ASTERISK_ARI_SECRET=change_me_ari_secret
ASTERISK_CONTEXT=from-internal
ASTERISK_TRUNK_CONTEXT=from-trunk

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OmniSuite <noreply@yourdomain.com>"

# --- File Upload ---
UPLOAD_MAX_SIZE=52428800
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,audio/ogg,audio/mpeg,video/mp4
UPLOAD_DEST=./uploads

# --- Recordings ---
RECORDINGS_PATH=./recordings

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Logs ---
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# --- Encryption ---
ENCRYPTION_KEY=change_me_32_char_encryption_key_

# --- CORS ---
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001,http://localhost:3002
